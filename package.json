{
  "name": "boxing-booking-miniapp",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev:db": "docker compose up -d mysql",
    "dev:status": "node scripts/dev-status.mjs",
    "dev:status:strict": "node scripts/dev-status.mjs --strict",
    "dev:status:test": "node --test scripts/dev-status.test.mjs",
    "dev:preview:start": "node scripts/dev-preview.mjs start",
    "dev:preview:stop": "node scripts/dev-preview.mjs stop",
    "dev:preview:status": "pnpm dev:status:strict",
    "verify": "pnpm --filter @booking/api prisma:generate && pnpm lint && pnpm --filter @booking/api test:e2e && node --test scripts/*.test.mjs && pnpm security:check && pnpm build",
    "stop:db": "docker compose down",
    "db:logs": "docker compose logs -f mysql",
    "api:dev": "pnpm --filter @booking/api start:dev",
    "admin:dev": "pnpm --filter @booking/admin dev",
    "miniapp:dev": "cross-env TARO_APP_AUTH_MODE=wechat pnpm --filter @booking/miniapp dev:weapp",
    "miniapp:dev:local": "cross-env TARO_APP_AUTH_MODE=dev pnpm --filter @booking/miniapp dev:weapp",
    "miniapp:visual-qa": "node scripts/miniapp-visual-qa.mjs",
    "miniapp:visual-qa:capture": "node scripts/miniapp-visual-qa.mjs --capture",
    "miniapp:visual-qa:capture-next": "node scripts/miniapp-visual-qa.mjs --capture --target-next",
    "miniapp:visual-qa:check": "node scripts/miniapp-visual-qa.mjs --check-matrix",
    "miniapp:visual-qa:plan": "node scripts/miniapp-visual-qa.mjs --manual-plan",
    "miniapp:visual-qa:next": "node scripts/miniapp-visual-qa.mjs --next-missing",
    "miniapp:visual-qa:test": "node --test scripts/miniapp-visual-qa.test.mjs",
    "miniapp:compliance:test": "node --test scripts/miniapp-compliance-entry.test.mjs",
    "miniapp:booking-rules:test": "node --test scripts/miniapp-booking-rules.test.mjs",
    "miniapp:booking-success:test": "node --test scripts/miniapp-booking-success.test.mjs",
    "miniapp:tab-labels:test": "node --test scripts/miniapp-tab-labels.test.mjs",
    "miniapp:class-card:test": "node --test scripts/miniapp-class-card.test.mjs",
    "miniapp:class-date-groups:test": "node --test scripts/miniapp-class-date-groups.test.mjs",
    "miniapp:class-date-filter:test": "node --test scripts/miniapp-class-date-filter.test.mjs",
    "miniapp:class-detail:test": "node --test scripts/miniapp-class-detail.test.mjs",
    "miniapp:class-availability:test": "node --test scripts/miniapp-class-availability.test.mjs",
    "miniapp:page-states:test": "node --test scripts/miniapp-page-states.test.mjs",
    "miniapp:pull-refresh:test": "node --test scripts/miniapp-pull-refresh.test.mjs",
    "miniapp:action-lock:test": "node --test scripts/miniapp-action-lock.test.mjs",
    "miniapp:network-errors:test": "node --test scripts/miniapp-network-errors.test.mjs",
    "miniapp:profile-summary:test": "node --test scripts/miniapp-profile-summary.test.mjs",
    "miniapp:status-labels:test": "node --test scripts/miniapp-status-labels.test.mjs",
    "admin:class-cancel:test": "node --test scripts/admin-class-cancel.test.mjs",
    "admin:class-reschedule:test": "node --test scripts/admin-class-reschedule.test.mjs",
    "admin:coaches:test": "node --test scripts/admin-coaches.test.mjs",
    "admin:class-roster:test": "node --test scripts/admin-class-roster.test.mjs",
    "admin:booking-export:test": "node --test scripts/admin-booking-export.test.mjs",
    "admin:booking-cancel:test": "node --test scripts/admin-booking-cancel.test.mjs",
    "admin:member-ledger:test": "node --test scripts/admin-member-ledger.test.mjs",
    "admin:notifications:test": "node --test scripts/admin-notifications.test.mjs",
    "admin:metrics:test": "node --test scripts/admin-metrics.test.mjs",
    "admin:network-errors:test": "node --test scripts/admin-network-errors.test.mjs",
    "admin:form-warnings:test": "node --test scripts/admin-form-warnings.test.mjs",
    "notifications:booking-confirmation:test": "node --test scripts/booking-confirmation-notification.test.mjs",
    "ops:alerting:test": "node --test scripts/ops-alerting.test.mjs",
    "ops:readiness:test": "node --test scripts/ops-readiness.test.mjs",
    "ops:staging:test": "node --test scripts/staging-readiness.test.mjs",
    "ops:release-checklist:test": "node --test scripts/release-checklist.test.mjs",
    "ops:manual-test-checklist:test": "node --test scripts/manual-test-checklist.test.mjs",
    "ops:manual-test:status": "node scripts/manual-test-status.mjs",
    "ops:manual-test:readiness": "node scripts/manual-test-readiness.mjs",
    "ops:third-party-notices:test": "node --test scripts/third-party-notices.test.mjs",
    "db:backup": "node scripts/db-backup.mjs",
    "db:restore": "node scripts/db-restore.mjs",
    "db:maintenance:test": "node --test scripts/db-maintenance.test.mjs",
    "security:audit": "pnpm audit --prod",
    "security:check": "pnpm security:check-secrets:test && pnpm security:check-logging:test && pnpm db:maintenance:test && pnpm security:check-secrets && pnpm security:check-logging && pnpm security:audit",
    "security:check-logging": "node scripts/check-sensitive-logging.mjs",
    "security:check-logging:test": "node --test scripts/check-sensitive-logging.test.mjs",
    "security:check-secrets": "node scripts/check-secrets.mjs",
    "security:check-secrets:test": "node --test scripts/check-secrets.test.mjs",
    "test": "pnpm --filter @booking/api test:e2e",
    "build": "pnpm --filter @booking/api build && pnpm --filter @booking/admin build && pnpm --filter @booking/miniapp build:weapp",
    "lint": "pnpm --filter @booking/api lint && pnpm --filter @booking/admin lint && pnpm --filter @booking/miniapp lint"
  },
  "pnpm": {
    "overrides": {
      "@tarojs/helper>esbuild": "0.28.1",
      "lodash-es": "4.18.1",
      "swiper": "12.1.2"
    },
    "patchedDependencies": {
      "@swc/register@0.1.10": "patches/@swc__register@0.1.10.patch"
    }
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "miniprogram-automator": "0.12.1"
  }
}
